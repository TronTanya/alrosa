# Можно держать здесь или в .env в КОРНЕ репозитория (корневой файл перекрывает этот).
#
# Минимум для FastAPI + Nylas v3:
NYLAS_API_KEY=
#
# Регион: US по умолчанию. Для EU:
# NYLAS_API_URI=https://api.eu.nylas.com
#
# OAuth client_id обычно НЕ нужен: подставляется автоматически (GET /v3/applications).
# Укажите вручную только если нужно переопределить:
# NYLAS_CLIENT_ID=
#
# CORS (опционально)
# NYLAS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# Scope: пусто = Graph Calendars.Read + ReadWrite; none = дефолт коннектора Nylas
# NYLAS_SCOPES=none
