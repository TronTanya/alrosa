# Скопируйте в файл .env в корне проекта (не коммитьте .env).
# После правок перезапустите: npm run dev
#
# Прокси Vite подставит ключ к api.deepseek.com (не светится в бандле):
DEEPSEEK_API_KEY=sk-...

# Или только этот — тоже подхватится прокси в dev (ключ попадёт в клиентскую сборку):
# VITE_DEEPSEEK_API_KEY=

# URL календаря Outlook Web на вкладке «Календарь» (по умолчанию — outlook.office.com/calendar/)
# VITE_OUTLOOK_CALENDAR_URL=https://outlook.office.com/calendar/

# --- Microsoft 365 / Outlook (Microsoft Graph) ---
# 1. Azure Portal → Microsoft Entra ID → App registrations → New registration.
# 2. Тип учётных записей (Supported account types):
#    — Личная @outlook.com / @live.com: нужен тип «в любом организационном каталоге И личные Microsoft».
#      Иначе на login.live.com: unauthorized_client / not enabled for consumers.
#    — Только сотрудники организации: «только в этом каталоге» или VITE_MSAL_AUTHORITY=.../organizations
# 3. Redirect URI: Single-page application (SPA) → http://localhost:5173/ (и прод-URL).
# 4. API permissions → Microsoft Graph → Delegated: User.Read, Calendars.Read → Grant admin consent при необходимости.
# 5. Скопируйте Application (client) ID:
# VITE_MSAL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Необязательно: свой tenant вместо /common
# VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/common
# Если redirect отличается от origin (редко для SPA):
# VITE_MSAL_REDIRECT_URI=http://localhost:5173/
# Авто-вход на странице «Календарь»: тихий SSO, затем редирект на Microsoft (false — только кнопка «Войти»)
# VITE_MSAL_AUTO_LOGIN=true
# Подсказка UPN для корпоративного tenant (ускоряет ssoSilent)
# VITE_MSAL_LOGIN_HINT=user@company.com

# --- Nylas + Outlook (FastAPI: npm run backend:nylas) ---
# Callback в Nylas Dashboard: http://localhost:5173/employee/calendar
# Достаточно API key; client_id подтягивается из API (или см. backend/.env.example).
# NYLAS_API_KEY=nyk_v0_...
# NYLAS_API_URI=https://api.eu.nylas.com
# NYLAS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Прокси Vite на бэкенд (пусто = относительный /nylas):
# VITE_NYLAS_API_BASE=http://localhost:8000
