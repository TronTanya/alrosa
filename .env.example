# Yandex Cloud Foundation Models (ЯндексGPT / Алиса): HR-инсайты, ИИ-наставник, подбор курсов — см. /hr/mentor
YANDEX_CLOUD_API_KEY=

# --- Яндекс.Календарь (OAuth 2.0, страница /employee/calendar) ---
# В https://oauth.yandex.ru/ у приложения в «Запрашиваемые права» должны быть:
#   • Календарь (Яндекс.Календарь) → calendar:read
#   • Доступ к информации о пользователе → login:info
# Не оставляйте только «Яндекс.Диск» — токен не даст доступ к CalDAV.
# Redirect URI (точное совпадение): http://localhost:5173/employee/calendar
# После правок .env перезапустите npm run dev. Секрет не префиксуйте VITE_ (не попадает в бандл).
VITE_YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
